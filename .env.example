# ============================================================
# YOJANA AI — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub!
# ============================================================

# ---- SUPABASE ----
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- GOOGLE GEMINI AI ----
# Get from: https://aistudio.google.com/app/apikey (FREE)
GEMINI_API_KEY=your-gemini-api-key-here

# ---- JOBS API (optional, add later) ----
# Get from: https://developer.adzuna.com (free 250 calls/day)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ---- APP CONFIG ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Yojana AI
